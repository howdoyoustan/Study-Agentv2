WAIP_API_KEY=
WAIP_API_ENDPOINT=https://api.waip.wiprocms.com
WAIP_DATASET_ID=

# Optional: override the default model (default: gpt-4o)
# WAIP_MODEL_NAME=gpt-4o

# Exposed to the browser for direct-to-WAIP large-file uploads.
# These bypass the Next.js request body size limit so files of any
# size can be sent directly from the browser to WAIP.
NEXT_PUBLIC_WAIP_API_ENDPOINT=https://api.waip.wiprocms.com
NEXT_PUBLIC_WAIP_API_KEY=
NEXT_PUBLIC_WAIP_DATASET_ID=
